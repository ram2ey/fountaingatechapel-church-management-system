{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and role",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["member", "leader", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "photoUrl": { "type": "string" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "PrayerRequest": {
      "title": "Prayer Request",
      "description": "A prayer request posted by a member",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "encouragementCount": { "type": "integer" },
        "prayingUsers": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["authorId", "authorName", "content", "timestamp"]
    },
    "SmallGroup": {
      "title": "Small Group",
      "description": "A group for Bible study or community",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "leaderId": { "type": "string" },
        "leaderName": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "meetingTime": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["name", "leaderId", "members"]
    },
    "Sermon": {
      "title": "Sermon",
      "description": "Past message audio/video and notes",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "speaker": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "videoUrl": { "type": "string" },
        "audioUrl": { "type": "string" },
        "notes": { "type": "string" },
        "scriptureRefs": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "speaker", "date"]
    },
    "Donation": {
      "title": "Donation",
      "description": "Financial giving record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["one-time", "recurring"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "category": { "type": "string" }
      },
      "required": ["userId", "amount", "timestamp"]
    },
    "AttendanceRecord": {
      "title": "Attendance Record",
      "description": "Check-in for a service or program",
      "type": "object",
      "properties": {
        "eventName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "attendees": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["eventName", "date"]
    },
    "ReadingPlan": {
      "title": "Reading Plan",
      "description": "Bible reading schedule",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "days": { "type": "array", "items": { 
          "type": "object",
          "properties": {
            "day": { "type": "integer" },
            "scripture": { "type": "string" }
          }
        }},
        "participants": { "type": "object" } 
      },
      "required": ["title"]
    },
    "Devotional": {
      "title": "Daily Devotional",
      "description": "Message from leadership",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "author": { "type": "string" }
      },
      "required": ["date", "title", "content"]
    }
  },
  "firestore": {
    "users": { "schema": "User", "description": "Global user directory" },
    "prayer_requests": { "schema": "PrayerRequest", "description": "Community prayer wall" },
    "small_groups": { "schema": "SmallGroup", "description": "Small groups and Bible studies" },
    "sermons": { "schema": "Sermon", "description": "Searchable sermon archives" },
    "donations": { "schema": "Donation", "description": "Private giving history" },
    "attendance": { "schema": "AttendanceRecord", "description": "Service check-ins" },
    "reading_plans": { "schema": "ReadingPlan", "description": "Bible reading plans" },
    "devotionals": { "schema": "Devotional", "description": "Daily devotionals" }
  }
}
